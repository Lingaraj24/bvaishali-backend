# ─────────────────────────────────────────────
# B Vaishali API — Environment Variables
# Copy to .env and fill in values
# ─────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://bvaishali:YOUR_PASSWORD@localhost:5432/bvaishali?schema=public"
POSTGRES_PASSWORD="YOUR_PASSWORD"   # used by docker-compose.yml

# JWT (generate with: openssl rand -base64 64)
JWT_SECRET="REPLACE_WITH_64_BYTE_SECRET"
JWT_EXPIRES_IN="7d"

# Google OAuth (console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# Frontend URL (for OAuth redirect)
WEB_URL="http://localhost:3000"

# Redis
REDIS_URL="redis://localhost:6379"

# Cloudflare R2
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="bvaishali-media"
R2_PUBLIC_URL="https://media.bvaishali.com"

# WATI (WhatsApp Business API — wati.io)
WATI_API_URL="https://live-server-xxx.wati.io"
WATI_API_KEY="your-wati-api-token"
WATI_ORDER_TEMPLATE="order_confirmation"

# Razorpay
RAZORPAY_KEY_ID="rzp_live_xxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# PayPal
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_ENVIRONMENT="sandbox" # Change to "production" when live

# ClickPost (Logistics)
CLICKPOST_API_KEY="your-clickpost-api-key"
CLICKPOST_USERNAME="your-clickpost-username"

# Resend (Transactional Email)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# Sentry (Error Monitoring)
SENTRY_DSN="https://xxxx@oXXXXX.ingest.sentry.io/XXXXXXX"

# Cloudflare Turnstile (Bot Protection)
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"

# App
APP_PORT=3001
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# OTP Config
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_LIMIT=3
