# ─────────────────────────────────────────────────────────
# Copy this to /opt/bvaishali-api/.env on the server
# Fill in every value. NEVER commit the actual .env file.
# ─────────────────────────────────────────────────────────

# Your GitHub username/bvaishali-api (used to pull Docker image)
GITHUB_REPO=your-github-username/bvaishali-api

# Active image version — updated automatically on each deploy
# Set manually here only for the FIRST deploy or a manual rollback
IMAGE_TAG=v10.0.1

# Postgres (internal to Docker network — no port exposed)
POSTGRES_USER=bvaishali
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=bvaishali

# Redis password
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Google OAuth (must match Google Cloud Console exactly)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://api.bvaishali.com/api/v1/auth/google/callback

# Frontend Vercel URL
WEB_URL=https://bvaishali.com

# Cloudflare R2 storage
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=bvaishali-media
R2_PUBLIC_URL=https://media.bvaishali.com

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret

# Resend (transactional email)
RESEND_API_KEY=re_xxx

# Sentry error monitoring
SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0
